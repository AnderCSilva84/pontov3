rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userDocPath());
    }

    function userDoc() {
      return get(userDocPath()).data;
    }

    function isAdmin() {
      return userExists() && userDoc().role == "admin";
    }

    function myFuncionarioId() {
      return userExists() ? userDoc().funcionarioId : null;
    }

    function myFuncionarioDocPath() {
      return /databases/$(database)/documents/funcionarios/$(myFuncionarioId());
    }

    function myFuncionarioExists() {
      return userExists() && myFuncionarioId() != null && exists(myFuncionarioDocPath());
    }

    function myFuncionarioDoc() {
      return get(myFuncionarioDocPath()).data;
    }

    function myLocaisPermitidos() {
      return myFuncionarioExists() && myFuncionarioDoc().locaisPermitidos is list
        ? myFuncionarioDoc().locaisPermitidos
        : [];
    }

    // USERS
    match /users/{uid} {
      allow read: if signedIn() && (isAdmin() || request.auth.uid == uid);
      allow write: if isAdmin();
    }

    // FUNCIONARIOS
    match /funcionarios/{funcionarioId} {
      allow read: if signedIn() && (isAdmin() || myFuncionarioId() == funcionarioId);
      allow write: if isAdmin();
    }

    // LOCAIS (GPS)
    match /locais/{localId} {
      allow read: if signedIn() && (
        isAdmin() ||
        (myFuncionarioExists() && localId in myLocaisPermitidos())
      );
      allow write: if isAdmin();
    }

    // REGISTROS (log do ponto)
    match /registros/{id} {
      allow read: if signedIn() &&
        (isAdmin() || resource.data.funcionarioId == myFuncionarioId());

      allow create: if signedIn() &&
        (isAdmin() || request.resource.data.funcionarioId == myFuncionarioId());

      allow update, delete: if isAdmin();
    }

    // DIAS (resumo do ponto)
    match /dias/{id} {
      allow read: if signedIn() &&
        (isAdmin() || resource.data.funcionarioId == myFuncionarioId());

      allow create: if signedIn() &&
        (isAdmin() || request.resource.data.funcionarioId == myFuncionarioId());

      allow update: if signedIn() &&
        (isAdmin() || resource.data.funcionarioId == myFuncionarioId());

      allow delete: if isAdmin();
    }

    // CATÁLOGO DE COMPRAS (lista de itens da casa)
    match /catalogoCompras/{itemId} {
      allow read: if signedIn();     // funcionária e admin podem ver
      allow write: if isAdmin();     // só admin altera catálogo
    }

    // LISTA DE COMPRAS ATIVA
    match /listaCompras/{itemId} {

      // todos logados podem ver
      allow read: if signedIn();

      // funcionária pode solicitar itens
      allow create: if signedIn() &&
        (isAdmin() || request.resource.data.solicitadoPor == myFuncionarioId());

      // funcionária pode marcar solicitado / admin pode atualizar tudo
      allow update: if signedIn() &&
        (isAdmin() || resource.data.solicitadoPor == myFuncionarioId());

      // apenas admin pode apagar
      allow delete: if isAdmin();
    }

    // TAREFAS
    match /tarefas/{tarefaId} {
      allow read: if signedIn();

      // só admin cria tarefas
      allow create: if isAdmin();

      // admin pode atualizar tudo; funcionária só pode concluir
      allow update: if signedIn() && (
        isAdmin() ||
        (
          resource.data.concluida == false &&
          request.resource.data.concluida == true &&
          request.resource.data.titulo == resource.data.titulo &&
          request.resource.data.diaSemana == resource.data.diaSemana &&
          request.resource.data.dataAgendada == resource.data.dataAgendada &&
          request.resource.data.solicitadoPor == resource.data.solicitadoPor &&
          request.resource.data.solicitadoPorNome == resource.data.solicitadoPorNome
        )
      );

      allow delete: if isAdmin();
    }

    // AJUSTES DE PONTO (LOG)
    match /ajustesPonto/{ajusteId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

  }
}
